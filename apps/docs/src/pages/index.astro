---
// Placeholder landing. The storybook that used to live here moved to
// `/showcase` in 3C.9. 3C.10 rewrites this file into a marketing landing
// assembled from UIKit components.
import BaseLayout from '../layouts/BaseLayout.astro';
import AppHeader from '../components/site/AppHeader.astro';
import AppSidebar from '../components/site/AppSidebar.astro';
---

<BaseLayout
  title='freeCodeCamp UIKit — Components for campers who ship'
  description='A design system that looks like home. Dark by default, token-driven, accessible.'
>
  <div class='app' id='top'>
    <AppHeader />
    <div class='app__body'>
      <AppSidebar />
      <main class='app__main' id='content'>
        <section class='placeholder'>
          <p class='placeholder__kicker'>freeCodeCamp UIKit</p>
          <h1 class='placeholder__title'>Command-line Chic.</h1>
          <p class='placeholder__lede'>
            Dark by default. Token-driven. Accessible. The landing here is
            getting a fresh rewrite in 3C.10 — in the meantime every component
            is browsable on its own page or side-by-side in the storybook.
          </p>
          <p class='placeholder__actions'>
            <a
              class='placeholder__btn placeholder__btn--primary'
              href='/components'
            >
              Browse components →
            </a>
            <a class='placeholder__btn' href='/showcase'>
              Open the storybook
            </a>
            <a class='placeholder__btn' href='/guides'> Read the guides </a>
          </p>
        </section>
      </main>
    </div>
  </div>
</BaseLayout>

<style>
  .placeholder {
    padding: clamp(3rem, 8vw, 6rem) clamp(1.5rem, 4vw, 3rem);
    max-width: 72ch;
  }
  .placeholder__kicker {
    font-family: var(--font-mono);
    text-transform: lowercase;
    letter-spacing: 0.08em;
    color: var(--cta-background, #f1be32);
    margin: 0 0 0.75rem;
  }
  .placeholder__title {
    font-size: clamp(2rem, 6vw, 3.5rem);
    margin: 0 0 1rem;
    line-height: 1.05;
  }
  .placeholder__lede {
    color: var(--foreground-secondary, #dfdfe2);
    font-size: 1.125rem;
    margin: 0 0 2rem;
    max-width: 52ch;
  }
  .placeholder__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin: 0;
  }
  .placeholder__btn {
    padding: 0.5rem 1rem;
    border: 2px solid var(--background-tertiary, #2a2a40);
    font-family: var(--font-mono);
    color: var(--foreground-primary, #fff);
    text-decoration: none;
    transition: border-color 120ms ease;
  }
  .placeholder__btn:hover {
    border-color: var(--cta-background, #f1be32);
  }
  .placeholder__btn--primary {
    border-color: var(--cta-background, #f1be32);
    background: var(--cta-background, #f1be32);
    color: var(--cta-foreground, #0a0a23);
  }
</style>
