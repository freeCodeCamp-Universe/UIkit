---
import { getCollection, render } from 'astro:content';
import { Panel } from '@freecodecamp/uikit';
import BaseLayout from '../layouts/BaseLayout.astro';
import AppHeader from '../components/site/AppHeader.astro';
import { HandbookSidebar } from '../components/handbook/HandbookSidebar';
import Brand from '../components/handbook/Brand.astro';

const foundationId = (id: string): string => (id === 'colors' ? 'palette' : id);

const foundations = await getCollection('foundations');
const foundationSections = await Promise.all(
  foundations
    .sort((a, b) => a.data.order - b.data.order)
    .map(async entry => {
      const { Content } = await render(entry);
      return {
        entry,
        id: foundationId(entry.id),
        Content
      };
    })
);

const implementationLinks = [
  { id: 'install', label: 'Install' },
  { id: 'cdn', label: 'CDN' },
  { id: 'tailwind', label: 'Tailwind' },
  { id: 'recipes', label: 'Recipes' },
  { id: 'contributing', label: 'Contributing' }
] as const;

const handbookSections = [
  {
    label: 'Foundations',
    items: foundationSections.map(({ entry, id }) => ({
      id,
      label: entry.data.title
    }))
  },
  {
    label: 'Implementation',
    items: implementationLinks
  }
] as const;
---

<BaseLayout
  title='freeCodeCamp UIKit — Handbook'
  description='One-page reference — palette, typography, spacing, iconography, motion, voice, brand, install, CDN, overview, contributing.'
>
  <div class='app' id='top'>
    <AppHeader />
    <div class='app__body'>
      <div class='app__sidebar' id='app-sidebar'>
        <HandbookSidebar
          sections={handbookSections}
          currentHash={Astro.url.hash}
        />
      </div>
      <button
        class='app__backdrop'
        type='button'
        aria-hidden='true'
        tabindex='-1'
        data-nav-backdrop></button>
      <main class='content sidebar-layout__main' tabindex='-1'>
        <div class='content__inner'>
          <section class='hero' id='introduction'>
            <p class='hero__kicker'>Handbook</p>
            <h1 class='hero__title'>One page. Every rule.</h1>
            <p class='hero__lede'>
              Everything a builder needs to ship fluently with freeCodeCamp
              UIKit — tokens, type, motion, voice, brand, install, CDN, and how
              to contribute. Use the handbook navigation to jump between rules.
            </p>
          </section>

          {
            foundationSections.map(({ entry, id, Content }) => (
              <section class='section handbook-section' id={id}>
                <p class='section__eyebrow'>{entry.data.eyebrow}</p>
                <h2 class='section__title'>{entry.data.title}</h2>
                <p class='section__lede'>{entry.data.summary}</p>
                <div class='foundations'>
                  <Content />
                </div>
                {entry.id === 'brand' && <Brand />}
              </section>
            ))
          }

          <section class='section handbook-section' id='install'>
            <p class='section__eyebrow'>Install</p>
            <h2 class='section__title'>Install the kit</h2>
            <p class='section__lede'>
              Ship UIKit however you like — two patterns, identical output.
            </p>
            <Panel title='1 · Add the packages'>
              <pre><code>pnpm add @freecodecamp/uikit @freecodecamp/uikit-css</code></pre>
            </Panel>
            <Panel title='2 · Import the stylesheets'>
              <p>Tokens first, components second.</p>
              <pre><code>{`@import '@freecodecamp/uikit-css/tokens.css';
@import '@freecodecamp/uikit-css/components.css';`}</code></pre>
            </Panel>
            <Panel title='3 · Use the components'>
              <pre><code>{`import { Button } from '@freecodecamp/uikit';

<Button variant="cta">Start curriculum</Button>`}</code></pre>
            </Panel>
          </section>

          <section class='section handbook-section' id='cdn'>
            <p class='section__eyebrow'>CDN</p>
            <h2 class='section__title'>Use via CDN</h2>
            <p class='section__lede'>
              One <code>@import</code> line pulls every token, every component class,
              and every font. Fonts resolve relative to the stylesheet URL.
            </p>
            <Panel title='CSS @import'>
              <pre><code>{`@import url('https://cdn.freecodecamp.org/uikit/styles.min.css');`}</code></pre>
            </Panel>
            <Panel title='Or the <link> tag'>
              <pre><code>{`<link
  rel="stylesheet"
  href="https://cdn.freecodecamp.org/uikit/styles.min.css"
  crossorigin="anonymous"
/>`}</code></pre>
            </Panel>
            <p>
              Pin a specific version by swapping the root for
              <code>https://cdn.freecodecamp.org/uikit/v1.0.0/</code>. The
              un-versioned URL always serves <code>latest</code>.
            </p>
          </section>

          <section class='section handbook-section' id='tailwind'>
            <p class='section__eyebrow'>Tailwind</p>
            <h2 class='section__title'>Use with Tailwind</h2>
            <p class='section__lede'>
              The Tailwind preset is a thin layer that translates every UIKit
              token into a Tailwind utility prefix. <code
                >bg-cta-background</code
              > reads the same CSS custom property the BEM classes do, so palette
              switches stay synchronized across both surfaces.
            </p>
            <Panel title='1 · Install'>
              <pre><code>{`pnpm add tailwindcss @freecodecamp/uikit-tailwind @freecodecamp/uikit-css`}</code></pre>
            </Panel>
            <Panel title='2 · Wire it up'>
              <pre><code>{`// tailwind.config.js
import fcc from '@freecodecamp/uikit-tailwind';

export default {
  presets: [fcc],
  content: ['./src/**/*.{ts,tsx,astro,html}'],
  theme: { extend: {} }
};`}</code></pre>
              <pre><code>{`/* src/index.css */
@import 'tailwindcss';
@import '@freecodecamp/uikit-css';`}</code></pre>
            </Panel>
            <Panel title='3 · Pick a pattern'>
              <p>
                Don't double-import utility surfaces. Pick one of these two
                patterns:
              </p>
              <ol class='guide-list handbook-steps'>
                <li>
                  <strong>Tailwind utility-first</strong> — import
                  <code>tailwindcss</code> only; let the preset surface the tokens.
                  Skip <code>uikit-css</code> entirely.
                </li>
                <li>
                  <strong>BEM-first + Tailwind escape hatch</strong> — import both,
                  but order <code>uikit-css</code> before
                  <code>tailwindcss</code> so utility classes win the cascade.
                </li>
              </ol>
              <p>
                The shipped docs site uses (2): BEM ships as the canonical
                surface in the playground, and the preset is the way to drop
                into Tailwind for project-specific work.
              </p>
            </Panel>
            <Panel title='Palette switching'>
              <p>
                The preset reads CSS custom properties at runtime, so swapping
                <code>{`<html class="dark-palette">`}</code> for
                <code>light-palette</code> instantly recolors every
                <code>bg-*</code>, <code>text-*</code>, and
                <code>border-*</code> utility. No build step.
              </p>
            </Panel>
          </section>

          <section class='section handbook-section' id='recipes'>
            <p class='section__eyebrow'>Recipes</p>
            <h2 class='section__title'>Compose components</h2>
            <p class='section__lede'>
              The playground shows each component in isolation. These recipes
              collect the patterns that compose two or more.
            </p>
            <Panel title='Form composition'>
              <pre><code>{`import { FormGroup, Input, HelpBlock, Button } from '@freecodecamp/uikit';

export function NewsletterForm() {
  return (
    <form onSubmit={onSubmit}>
      <FormGroup>
        <label htmlFor='email'>Email address</label>
        <Input id='email' type='email' required />
        <HelpBlock>One curriculum update per week.</HelpBlock>
      </FormGroup>
      <Button type='submit' variant='cta'>Subscribe</Button>
    </form>
  );
}`}</code></pre>
            </Panel>
            <Panel title='Modal from a button'>
              <pre><code>{`import { useState } from 'react';
import { Modal, Button } from '@freecodecamp/uikit';

export function ResetCta() {
  const [open, setOpen] = useState(false);
  return (
    <>
      <Button variant='danger' onClick={() => setOpen(true)}>
        Reset progress
      </Button>
      <Modal open={open} onClose={() => setOpen(false)} title='Reset progress?'>
        <Modal.Body>You will lose 17 of 32 steps.</Modal.Body>
        <Modal.Footer>
          <Button onClick={() => setOpen(false)}>Cancel</Button>
          <Button variant='danger' onClick={confirmReset}>Confirm</Button>
        </Modal.Footer>
      </Modal>
    </>
  );
}`}</code></pre>
            </Panel>
            <Panel title='Toast on action'>
              <pre><code>{`import { useToast, Button } from '@freecodecamp/uikit';

export function SaveButton() {
  const toast = useToast();
  return (
    <Button
      onClick={() => {
        save();
        toast.create({
          title: 'Saved',
          description: 'Your progress is synced.',
          variant: 'success'
        });
      }}
    >
      Save
    </Button>
  );
}`}</code></pre>
            </Panel>
            <Panel title='Sidebar layout with navbar'>
              <pre><code>{`import { SidebarLayout, Navbar, Sidebar } from '@freecodecamp/uikit';

export function Shell({ children }) {
  return (
    <SidebarLayout
      header={<Navbar start={<Brand />} end={<UserMenu />} />}
      aside={<Sidebar sections={navSections} />}
    >
      {children}
    </SidebarLayout>
  );
}`}</code></pre>
            </Panel>
          </section>

          <section class='section handbook-section' id='contributing'>
            <p class='section__eyebrow'>Contributing</p>
            <h2 class='section__title'>Contribute a change</h2>
            <p class='section__lede'>
              UIKit lives in the <a
                class='fcc-link'
                href='https://github.com/freeCodeCamp/UIkit'
                >freeCodeCamp/UIkit</a
              > monorepo. Small fixes go straight to PR; larger features start with
              a short RFC in a GitHub Discussion.
            </p>
            <ol class='guide-list handbook-steps'>
              <li>Fork the repo and branch off <code>main</code>.</li>
              <li>
                One concern per commit. TDD: failing test → implementation →
                green.
              </li>
              <li>
                Commit with <code>type(scope): subject</code> — title-only, no body.
                Use <code>feat</code>, <code>fix</code>, <code>refactor</code>, <code
                  >chore</code
                >, <code>docs</code>, or <code>test</code>.
              </li>
              <li>
                Run the full battery locally before pushing:
                <pre><code>{`pnpm install
pnpm test
pnpm build
pnpm format:check
pnpm --filter @freecodecamp/uikit-docs test:visual`}</code></pre>
              </li>
              <li>
                Add a Changeset for user-visible changes —
                <code>pnpm changeset</code>. Pick packages, bump type, and write
                a one-line summary.
              </li>
              <li>
                Open a PR against <code>main</code>. CodeRabbit reviews; CI is
                the source of truth. Releases cut from merged PRs — individual
                PRs don't publish.
              </li>
            </ol>
          </section>

          <footer class='footer'>
            <p>
              freeCodeCamp UIKit · <a href='/'>Home</a> · <a
                href='https://github.com/freeCodeCamp/UIkit'>Source</a
              >.
            </p>
          </footer>
        </div>
      </main>
    </div>
  </div>

  <script>
    import '../scripts/showcase-spy.client.ts';
  </script>
</BaseLayout>
