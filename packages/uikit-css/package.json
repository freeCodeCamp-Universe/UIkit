{
  "name": "@freecodecamp/uikit-css",
  "version": "0.1.0",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "build": "echo '[uikit-css] ships source — no build' && exit 0",
    "lint": "oxfmt --check src"
  },
  "author": "freeCodeCamp.org <team@freecodecamp.org>",
  "license": "BSD-3-Clause",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/freeCodeCamp/UIkit.git",
    "directory": "packages/uikit-css"
  },
  "bugs": {
    "url": "https://github.com/freeCodeCamp/UIkit/issues"
  },
  "homepage": "https://design.freecodecamp.org",
  "description": "Tokens + component CSS + fonts for the freeCodeCamp UIKit",
  "sideEffects": [
    "**/*.css"
  ],
  "style": "./src/index.css",
  "exports": {
    ".": "./src/index.css",
    "./index.css": "./src/index.css",
    "./tokens.css": "./src/tokens.css",
    "./components.css": "./src/components.css",
    "./fonts/*": "./src/fonts/*",
    "./brand/*": "./src/brand/*",
    "./package.json": "./package.json",
    "./base.css": "./src/base.css",
    "./html/*": "./src/html/*"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "vitest": "4.1.5"
  },
  "private": true
}
